{
  "name": "TuitionPayment",
  "type": "object",
  "properties": {
    "student_email": {
      "type": "string"
    },
    "student_name": {
      "type": "string"
    },
    "course_id": {
      "type": "string"
    },
    "course_name": {
      "type": "string"
    },
    "amount": {
      "type": "number"
    },
    "payment_date": {
      "type": "string",
      "format": "date"
    },
    "method": {
      "type": "string",
      "enum": [
        "cash",
        "bank_transfer",
        "credit_card",
        "online"
      ],
      "default": "cash"
    },
    "status": {
      "type": "string",
      "enum": [
        "paid",
        "pending",
        "overdue",
        "partial"
      ],
      "default": "pending"
    },
    "notes": {
      "type": "string"
    }
  },
  "required": [
    "student_email",
    "course_id",
    "amount"
  ]
}