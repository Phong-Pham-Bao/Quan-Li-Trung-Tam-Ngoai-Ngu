{
  "name": "Enrollment",
  "type": "object",
  "properties": {
    "student_email": {
      "type": "string",
      "description": "Student email"
    },
    "student_name": {
      "type": "string",
      "description": "Student display name"
    },
    "course_id": {
      "type": "string",
      "description": "Course ID"
    },
    "course_name": {
      "type": "string",
      "description": "Course name for display"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "completed",
        "dropped",
        "pending"
      ],
      "default": "active"
    },
    "enrollment_date": {
      "type": "string",
      "format": "date"
    }
  },
  "required": [
    "student_email",
    "course_id"
  ]
}